class Main {
    public static void main(String[] args) {
        int a[] = {12,33,24,5,7,6};
        int min = a[0];
        int max = a[0];
        for(int i=1;i<a.length;i++){
            if(min> a[i]){
                min = a[i];
            }
            if(a[i] > max){
                max = a[i];
            }
        }
        System.out.println(min);
        System.out.println(max);
    }
}
